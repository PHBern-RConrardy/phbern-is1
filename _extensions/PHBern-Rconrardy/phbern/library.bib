@article{celik2023,
  title = {Towards {{Intelligent-TPACK}}: {{An}} Empirical Study on Teachers' Professional Knowledge to Ethically Integrate Artificial Intelligence ({{AI}})-Based Tools into Education},
  shorttitle = {Towards {{Intelligent-TPACK}}},
  author = {Celik, Ismail},
