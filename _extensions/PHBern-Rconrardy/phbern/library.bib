@article{costello2025,
  title = {Authoritarian {{EdTech}}},
  author = {Costello, Eamon and Gow, Stephen},
  year = 2025,
  month = dec,
  journal = {Dialogues on Digital Society},
  volume = {1},
  number = {3},
