@article{chan2021,
  title = {Virtual Chemical Laboratories: {{A}} Systematic Literature Review of Research, Technologies and Instructional Design},
  shorttitle = {Virtual Chemical Laboratories},
  author = {Chan, Philippe and Van Gerven, Tom and Dubois, Jean-Luc and Bernaerts, Kristel},
  year = 2021,
  month = dec,
  journal = {Computers and Education Open},
  volume = {2},
  pages = {100053},
  issn = {2666-5573},
  doi = {10.1016/j.caeo.2021.100053},
  urldate = {2026-04-24},
  abstract = {Practical laboratory courses are an essential part of chemistry education. However, they can be costly and time-consuming. They also require physical presence of the teacher and students and access to well-equipped laboratories, which can be hindered due to equipment cost or a pandemic lockdown. Virtual chemical laboratories are digital tools that become very useful in these situations, but what research has been done on these tools and what elements are important in terms of technology and instructional design? This systematic literature review presents an extensive overview of previous research and addresses the different types of technology and instructional design elements. Results of this study show that virtual labs can be more effective than passive teaching methods (e.g., lecture, text and video), but show equal or greater effectiveness compared to hands-on laboratory. Better results are shown when virtual labs and traditional methods are combined. Most of the included studies use 3D Desktop technology, while immersive VR technology is trending in the last few years. This review also identified instructional design elements used in context of virtual chemical labs, for example, inquiry-based learning, modality, instructional scaffolding. Virtual laboratories can be used as an effective complementary tool or temperate alternative to real hands-on laboratory, but future research should put more emphasis in investigating skill-based learning outcomes using immersive VR and NUI technologies and in considering instructional design in virtual chemical laboratories.},
  keywords = {Chemistry,Distance education and online learning,Media in education,Virtual laboratory,Virtual reality},
  file = {/Users/richard/Zotero/storage/KY9F7EZD/Chan et al. - 2021 - Virtual chemical laboratories A systematic literature review of research, technologies and instruct.pdf;/Users/richard/Zotero/storage/R6QCK2PM/S2666557321000240.html}
}

