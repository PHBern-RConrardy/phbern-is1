  keywords = {Adaptiver Unterricht,Bildungsforschung,Conception of teaching,Educational research,Lehr-Lern-Forschung,Method,Methode,School,Schule,Teaching,Teaching quality,Teaching-learning research,Unterricht,Unterrichtskonzeption,Unterrichtsqualitat}
