  keywords = {Academic achievement,Autonomous motivation,Intrinsic motivation,Longitudinal,School performance,Self-determination},
  file = {/Users/richard/Zotero/storage/FGAVHRJP/Taylor et al. - 2014 - A self-determination theory approach to predicting.pdf;/Users/richard/Zotero/storage/4CKKAJAJ/S0361476X14000514.html}
