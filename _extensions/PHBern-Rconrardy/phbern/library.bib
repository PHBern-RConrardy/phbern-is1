@article{koehler2013,
  title = {What Is {{Technological Pedagogical Content Knowledge}} ({{TPACK}})?},
  author = {Koehler, Matthew J. and Mishra, Punya and Cain, William},
  year = 2013,
  month = oct,
  journal = {Journal of Education},
  volume = {193},
