  file = {/Users/richard/Zotero/storage/59DMK5N8/Henrie et al. - 2015 - Measuring student engagement in technology-mediated learning A review.pdf;/Users/richard/Zotero/storage/5BCMPQHG/S0360131515300427.html}
}

@misc{hermann2025,
  type = {{{SSRN Scholarly Paper}}},
  title = {Conversational {{AI}}: {{The Next Frontier}} of {{Digital Platform Monetization}}},
  shorttitle = {Conversational {{AI}}},
  author = {Hermann, Erik and Puntoni, Stefano and Schweidel, David A.},
  year = 2025,
  month = oct,
  number = {5634270},
  eprint = {5634270},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  doi = {10.2139/ssrn.5634270},
  urldate = {2026-03-04},
  abstract = {Conversational AI has become a widespread and dominant consumer interface. At the same time, AI providers face pressure to monetize their free-to-use tools through advertising. Against this backdrop, we argue that conversational AI can establish a new logic of digital platform monetization: from monetizing intent (search engines) and attention (social media) to monetizing immersive interactions. We identify three distinguishing characteristics enabling such immersive interactions: (1) native integration into conversations, (2) adaptive targeting and personalization, and (3) social presence and relational interactions. We then delineate a typology of conversational AI ads along the dimensions of targeting and obtrusiveness. The most appealing yet controversial format is contextual native ads (high targeting, low obtrusiveness), that are highly targeted, personalized responses seamlessly embedded into conversational AI outputs. This ad format---and conversational AI advertising more broadly---can cause interactional and ad system tensions across stakeholders (consumers, AI providers, advertisers). To address these tensions and align value creation and capture, we lay out our PACE framework based on the AI ethics principles Privacy, Autonomy, (fair) Competition, Explicability and a comprehensive research agenda. Thereby, our work contributes to the research on (i) digital marketing and platform monetization and (ii) platform ecosystems.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {artificial intelligence,conversational AI,digital platforms,generative AI,monetization,search engines,social media},
  file = {/Users/richard/Zotero/storage/9MXP2YEJ/Hermann et al. - 2025 - Conversational AI The Next Frontier of Digital Platform Monetization.pdf}
}

