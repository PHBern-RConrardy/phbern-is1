@article{hong2021,
  title = {Procrastination Predicts Online Self-Regulated Learning and Online Learning Ineffectiveness during the Coronavirus Lockdown},
  author = {Hong, Jon-Chao and Lee, Yi-Fang and Ye, Jian-Hong},
  year = 2021,
  month = may,
  journal = {Personality and Individual Differences},
  volume = {174},
  pages = {110673},
  issn = {0191-8869},
  doi = {10.1016/j.paid.2021.110673},
  urldate = {2023-05-28},
  abstract = {During the lockdown due to SARS-CoV-2 (coronavirus lockdown), there has been a tremendous increase in the number of students taking online courses. Few studies, however, have examined the individual dispositions that influence self-regulated online learning during the coronavirus lockdown. To address this gap, the present study explored the ineffectiveness of online learning and examined how it can be predicted by self-regulated online learning and participants' procrastination disposition. Data of 433 participants were collected and subjected to confirmatory factor analysis with structural equation modeling. The results indicated that procrastination is negatively related to 6 sub-constructs of self-regulated online learning: task strategy, mood adjustment, self-evaluation, environmental structure, time management, and help-seeking. These sub-constructs were negatively related to the learners' perceived ineffectiveness of online learning. However, the relationship between perceived learning ineffectiveness and environmental structure or help-seeking was weaker than that with task strategy or mood adjustment, indicating that the latter two subtypes of self-regulated online learning should be considered before students engage in online learning.},
  langid = {english},
  keywords = {Distance education and online learning,Teaching/learning strategies COVID-19 self-regulated learning procrastination},
  file = {/Users/richard/Zotero/storage/VCCKAZWZ/Hong et al. - 2021 - Procrastination predicts online self-regulated lea.pdf;/Users/richard/Zotero/storage/QI2VP8AC/S0191886921000489.html}
}

