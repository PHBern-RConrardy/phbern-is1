}

@article{coutinho2021,
  title = {Dunning-{{Kruger Effect}}: {{Intuitive Errors Predict Overconfidence}} on the {{Cognitive Reflection Test}}},
  shorttitle = {Dunning-{{Kruger Effect}}},
  author = {Coutinho, Mariana V. C. and Thomas, Justin and Alsuwaidi, Alia S. M. and Couchman, Justin J.},
  year = 2021,
